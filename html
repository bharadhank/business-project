                border: none;
                color: var(--text-muted);
                cursor: pointer;
                font-size: 20px;
                line-height: 1;
                padding: 4px;
            }

            .modal-close:hover {
                color: var(--text-primary);
            }

            .modal-footer {
                display: flex;
                gap: 10px;
                justify-content: flex-end;
                margin-top: 24px;
