        <script>
            /* ── STATE ─────────────────────────────────────────────────── */
            let currentPage = 'home';
            let projects = JSON.parse(localStorage.getItem('pp_projects') || '[]');
            let username = localStorage.getItem('pp_username') || '';
            let isDark = localStorage.getItem('pp_dark') === 'true';
            let firebaseUser = null;

            let filteredProjects = [...projects];
            let sortKey = '';
            let sortDir = 'asc';
            let tablePage = 1;
            const ROWS_PER_PAGE = 8;
            let editId = null;

            /* ── BOOT ──────────────────────────────────────────────────── */
            (function init() {
                applyTheme();
                if (username) document.getElementById('username-input').value = username;
                updateFinancials();
                document.getElementById('f-value').addEventListener('input', updateFinancials);
                document.getElementById('f-collected').addEventListener('input', updateFinancials);
                m_val(); // modal outstanding calc
            })();

            function m_val() {

                ['m-value',
                    'm-collected'].forEach(id => {
                        document.getElementById(id).addEventListener('input', () => {
                            const v = parseFloat(document.getElementById('m-value').value) || 0;
                            const c = parseFloat(document.getElementById('m-collected').value) || 0;
                        });
                    });
            }

            function updateFirebaseStatus(message, state = 'pending') {
                const el = document.getElementById('sb-firebase-status');
                if (!el) return;
                el.textContent = message;
                el.className = 'firebase-status ' + state;
            }

            function updateSyncStatus(message, state = 'pending') {
                const el = document.getElementById('sb-firestore-sync');
                if (!el) return;
                el.textContent = message;
                el.className = 'firebase-status ' + state;
            }

            function startFirebase() {
                updateFirebaseStatus('Connecting to Firebase...', 'pending');

                firebase.auth().signInAnonymously().catch(error => {
                    console.error('Firebase auth failed:', error);
                    updateFirebaseStatus('Offline', 'disconnected');
                    toast('Firebase auth failed. Using local cache only.', 'error');
                });

                firebase.auth().onAuthStateChanged(user => {
                    firebaseUser = user;
                    if (user) {
                        console.log('Firebase user:', user.uid);
                        updateFirebaseStatus('Firebase connected', 'connected');
                        loadProjects();
                    } else {
                        console.log('No user signed in');
                        updateFirebaseStatus('Not authenticated', 'disconnected');
                    }
                });
            }

            async function loadProjects() {
                if (!db || !firebaseUser) return;
                updateSyncStatus('Loading projects from Firestore...', 'pending');

                try {
                    const snapshot = await db.collection('projects').orderBy('createdAt', 'desc').get();
                    if (!snapshot.empty) {
                        projects = snapshot.docs.map(doc => {
                            const data = doc.data();
                            const numericId = Number(doc.id);
                            return {
                                ...data,
                                id: Number.isNaN(numericId) ? doc.id : numericId,
                                docId: doc.id
                            };
                        });
                        filteredProjects = [...projects];
                        saveToLocalCache();
                        updateSyncStatus('Firestore projects loaded', 'connected');
                    } else {
                        updateSyncStatus('No projects in Firestore yet', 'connected');
                    }
                } catch (error) {
                    console.error('Failed to load Firestore projects:', error);
                    updateSyncStatus('Failed to load Firestore', 'disconnected');
                    toast('Could not load projects from Firestore.', 'error');
                } finally {
                    renderTable();
                }
            }

            function saveToLocalCache() {
                localStorage.setItem('pp_projects', JSON.stringify(projects));
            }

            /* ── THEME ─────────────────────────────────────────────────── */
            function applyTheme() {
                document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
                const pill = document.getElementById('theme-pill');
                pill.classList.toggle('on', isDark);
            }

            function toggleTheme() {
                isDark = !isDark;
                localStorage.setItem('pp_dark', isDark);
                applyTheme();
            }

            /* ── NAVIGATION ────────────────────────────────────────────── */
            function navigate(page) {
                // Update pages
                document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
                document.getElementById('page-' + page).classList.add('active');

                // Update nav
                document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
                const navEl = document.getElementById('nav-' + page);
                if (navEl) navEl.classList.add('active');

                currentPage = page;
                if (page === 'table') renderTable();
                window.scrollTo(0, 0);
            }

            function toggleMobileNav() {
                document.getElementById('mobile-nav').classList.toggle('open');
            }

            function closeMobileNav() {
                document.getElementById('mobile-nav').classList.remove('open');
            }

            /* ── PAGE 1 — HOME ─────────────────────────────────────────── */
            function handleHomeSubmit() {
                const inp = document.getElementById('username-input');
                const err = document.getElementById('username-error');
                const val = inp.value.trim();

                if (!val) {
                    inp.classList.add('error');
                    err.classList.add('show');
                    inp.focus();
                    return;
                }

                inp.classList.remove('error');
                err.classList.remove('show');

                username = val;
                localStorage.setItem('pp_username', username);
                navigate('form');
                toast('Welcome, ' + username + '! Fill in your first project below.', 'success');
            }

            document.getElementById('username-input').addEventListener('keydown', e => {
                if (e.key === 'Enter') handleHomeSubmit();
            });

            /* ── PAGE 2 — FORM ─────────────────────────────────────────── */
            function updateFinancials() {
                const val = parseFloat(document.getElementById('f-value').value) || 0;
                const col = parseFloat(document.getElementById('f-collected').value) || 0;
                const out = Math.max(0, val - col);
                document.getElementById('f-outstanding').value = out ? out.toFixed(2) : '';
            }

            const REQUIRED_FIELDS = [{
                id: 'f-project-name', err: 'err-project-name', key: 'projectName'
            }

                ,
            {
                id: 'f-project-type', err: 'err-project-type', key: 'projectType'
            }

                ,
            {
                id: 'f-owner', err: 'err-owner', key: 'owner'
            }

                ,
            {
                id: 'f-leader', err: 'err-leader', key: 'leader'
            }

                ,
            {
                id: 'f-status', err: 'err-status', key: 'status'
            }

                ,
            {
                id: 'f-start', err: 'err-start', key: 'startDate'
            }

                ,
            {
                id: 'f-end', err: 'err-end', key: 'endDate'
            }

                ,
            {
                id: 'f-value', err: 'err-value', key: 'value'
            }

                ,
            ];

            async function handleFormSubmit() {
                let valid = true;

                REQUIRED_FIELDS.forEach(f => {
                    const el = document.getElementById(f.id);
                    const err = document.getElementById(f.err);

                    if (!el.value.trim()) {
                        el.classList.add('error');
                        err.classList.add('show');
                        valid = false;
                    }

                    else {
                        el.classList.remove('error');
                        err.classList.remove('show');
                    }
                });

                if (!valid) {
                    toast('Please fill in all required fields.', 'error');
                    return;
                }

                const val = parseFloat(document.getElementById('f-value').value) || 0;
                const col = parseFloat(document.getElementById('f-collected').value) || 0;

                const project = {
                    id: Date.now(),
                    projectName: document.getElementById('f-project-name').value.trim(),
                    projectType: document.getElementById('f-project-type').value.trim(),
                    owner: document.getElementById('f-owner').value.trim(),
                    leader: document.getElementById('f-leader').value.trim(),
                    crew: document.getElementById('f-crew').value.trim(),
                    status: document.getElementById('f-status').value,
                    startDate: document.getElementById('f-start').value,
                    endDate: document.getElementById('f-end').value,
                    value: val,
                    collected: col,
                    outstanding: Math.max(0, val - col),
                    createdBy: firebaseUser ? firebaseUser.uid : null,
                    createdAt: new Date().toISOString(),
                    docId: String(Date.now())
                };

                await saveProject(project);

                resetForm();
                navigate('table');
                toast('Project "' + project.projectName + '" saved successfully!', 'success');
            }

            async function saveProject(project) {
                projects.unshift(project);
                filteredProjects = [...projects];
                updateSyncStatus('Syncing new project...', 'pending');

                if (db && firebaseUser) {
                    try {
                        const docRef = db.collection('projects').doc(project.docId);
                        await docRef.set({
                            ...project,
                            createdAt: firebase.firestore.FieldValue.serverTimestamp()
                        });
                        updateSyncStatus('Project synced', 'connected');
                    } catch (error) {
                        console.error('Firestore save failed:', error);
                        updateSyncStatus('Sync failed', 'disconnected');
                        toast('Saved locally. Firestore sync failed.', 'error');
                    }
                } else {
                    updateSyncStatus('Offline: save queued locally', 'disconnected');
                }

                saveToLocalCache();
            }

            function resetForm() {
                REQUIRED_FIELDS.forEach(f => {
                    const el = document.getElementById(f.id);
                    const err = document.getElementById(f.err);
                    el.value = '';
                    el.classList.remove('error');
                    err.classList.remove('show');
                });

                ['f-crew',
                    'f-collected',
                    'f-outstanding'].forEach(id => {
                        document.getElementById(id).value = '';
                    });
            }

            /* ── PAGE 3 — TABLE ────────────────────────────────────────── */
            function renderTable() {
                // Sidebar
                document.getElementById('sb-username').textContent = username || 'Guest';
                const av = document.getElementById('sb-avatar');
                av.textContent = (username || 'G')[0].toUpperCase();

                // Stats
                document.getElementById('stat-total').textContent = projects.length;
                document.getElementById('stat-inprogress').textContent = projects.filter(p => p.status === 'In Progress').length;
                document.getElementById('stat-completed').textContent = projects.filter(p => p.status === 'Completed').length;
                document.getElementById('stat-onhold').textContent = projects.filter(p => p.status === 'On Hold').length;

                // Pagination
                const total = filteredProjects.length;
                const pages = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
                if (tablePage > pages) tablePage = pages;
                const start = (tablePage - 1) * ROWS_PER_PAGE;
                const end = Math.min(start + ROWS_PER_PAGE, total);
                const slice = filteredProjects.slice(start, end);

                const tbody = document.getElementById('table-body');

                if (!total) {
                    tbody.innerHTML = '<tr><td colspan="12"><div class="empty-state"><div class="empty-icon">📂</div><p>No projects found. <a href="#" onclick="navigate(\'form\');return false;" style="color:var(--accent)">Add your first project →</a></p></div></td></tr>';
                }

                else {
                    tbody.innerHTML = slice.map(p => ` <tr> <td class="fw-600" >${esc(p.projectName)}</td> <td>${esc(p.projectType)}</td> <td>${esc(p.owner)}</td> <td>${esc(p.leader)}</td> <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${esc(p.crew)}">${esc(p.crew) || '—'}</td> <td>${statusBadge(p.status)}</td> <td class="mono">${fmtDate(p.startDate)}</td> <td class="mono">${fmtDate(p.endDate)}</td> <td class="text-right mono fw-600">${fmtMoney(p.value)}</td> <td class="text-right mono" style="color:var(--success)">${fmtMoney(p.collected)}</td> <td class="text-right mono" style="color:${p.outstanding > 0 ? 'var(--danger)' : 'var(--text-muted)'}">${fmtMoney(p.outstanding)}</td> <td> <div class="row-actions"> <button class="btn btn-sm btn-secondary" onclick="openEdit(${p.id})" title="Edit">✏️</button> <button class="btn btn-sm btn-danger" onclick="deleteProject(${p.id})" title="Delete">🗑️</button> </div> </td> </tr>`).join('');
                }

                // Page info
                document.getElementById('page-info').textContent = total ? `Showing ${start + 1}–${end} of ${total} project${total !== 1 ? 's' : ''}` : 'No projects';

                // Page buttons
                const pgBtns = document.getElementById('page-btns');
                pgBtns.innerHTML = '';

                const addBtn = (label, pg, disabled, active) => {
                    const b = document.createElement('button');
                    b.className = 'page-btn' + (active ? ' active' : '');
                    b.innerHTML = label;
                    b.disabled = disabled;

                    b.onclick = () => {
                        tablePage = pg;
                        renderTable();
                    }

                        ;
                    pgBtns.appendChild(b);
                }

                    ;
                addBtn('‹', tablePage - 1, tablePage === 1, false);

                for (let i = 1; i <= pages; i++) {
                    if (pages > 7 && i > 2 && i < pages - 1 && Math.abs(i - tablePage) > 1) {
                        if (i === 3 || i === pages - 2) {
                            const s = document.createElement('span');
                            s.className = 'page-btn';
                            s.innerHTML = '…';
                            s.style.cursor = 'default';
                            pgBtns.appendChild(s);
                        }

                        continue;
                    }

                    addBtn(i, i, false, i === tablePage);
                }

                addBtn('›', tablePage + 1, tablePage === pages, false);
            }

            function handleSearch() {
                const q = document.getElementById('search-input').value.toLowerCase().trim();
                filteredProjects = q ? projects.filter(p => Object.values(p).some(v => String(v).toLowerCase().includes(q))) : [...projects];
                applySort();
                tablePage = 1;
                renderTable();
            }

            function sortTable(key) {
                if (sortKey === key) sortDir = sortDir === 'asc' ? 'desc' : 'asc';

                else {
                    sortKey = key;
                    sortDir = 'asc';
                }

                applySort();

                // Update header icons
                document.querySelectorAll('th').forEach(th => {
                    th.classList.remove('sort-asc', 'sort-desc');
                });

                document.querySelectorAll('th').forEach(th => {
                    if (th.getAttribute('onclick') === `sortTable('${key}')`) {
                        th.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
                        th.querySelector('.sort-icon').textContent = sortDir === 'asc' ? '↑' : '↓';
                    }
                });

                tablePage = 1;
                renderTable();
            }

            function applySort() {
                if (!sortKey) return;

                filteredProjects.sort((a, b) => {
                    let av = a[sortKey], bv = b[sortKey];
                    if (typeof av === 'number') return sortDir === 'asc' ? av - bv : bv - av;
                    return sortDir === 'asc' ? String(av).localeCompare(String(bv)) : String(bv).localeCompare(String(av));
                });
            }

            async function deleteProject(id) {
                if (!confirm('Delete this project? This cannot be undone.')) return;

                const project = projects.find(p => p.id === id);
                updateSyncStatus('Removing project from Firestore...', 'pending');

                if (db && firebaseUser && project) {
                    try {
                        await db.collection('projects').doc(project.docId || String(id)).delete();
                        updateSyncStatus('Project delete synced', 'connected');
                    } catch (error) {
                        console.error('Firestore delete failed:', error);
                        updateSyncStatus('Delete sync failed', 'disconnected');
                        toast('Project removed locally, Firestore delete failed.', 'error');
                    }
                } else {
                    updateSyncStatus('Offline: delete queued locally', 'disconnected');
                }

                projects = projects.filter(p => p.id !== id);
                filteredProjects = filteredProjects.filter(p => p.id !== id);
                saveToLocalCache();
                renderTable();
                toast('Project deleted.', 'info');
            }

            /* ── EDIT MODAL ────────────────────────────────────────────── */
            function openEdit(id) {
                const p = projects.find(x => x.id === id);
                if (!p) return;
                editId = id;
                document.getElementById('m-name').value = p.projectName;
                document.getElementById('m-type').value = p.projectType;
                document.getElementById('m-owner').value = p.owner;
                document.getElementById('m-leader').value = p.leader;
                document.getElementById('m-crew').value = p.crew;
                document.getElementById('m-status').value = p.status;
                document.getElementById('m-start').value = p.startDate;
                document.getElementById('m-end').value = p.endDate;
                document.getElementById('m-value').value = p.value;
                document.getElementById('m-collected').value = p.collected;
                document.getElementById('edit-modal').classList.add('open');
            }

            function closeModal() {
                document.getElementById('edit-modal').classList.remove('open');
                editId = null;
            }

            document.getElementById('edit-modal').addEventListener('click', e => {
                if (e.target === document.getElementById('edit-modal')) closeModal();
            });

            async function saveEdit() {
                const idx = projects.findIndex(p => p.id === editId);
                if (idx < 0) return;
                const val = parseFloat(document.getElementById('m-value').value) || 0;
                const col = parseFloat(document.getElementById('m-collected').value) || 0;

                projects[idx] = {
                    ...projects[idx],
                    projectName: document.getElementById('m-name').value.trim(),
                    projectType: document.getElementById('m-type').value.trim(),
                    owner: document.getElementById('m-owner').value.trim(),
                    leader: document.getElementById('m-leader').value.trim(),
                    crew: document.getElementById('m-crew').value.trim(),
                    status: document.getElementById('m-status').value,
                    startDate: document.getElementById('m-start').value,
                    endDate: document.getElementById('m-end').value,
                    value: val,
                    collected: col,
                    outstanding: Math.max(0, val - col),
                };

                const project = projects[idx];
                updateSyncStatus('Syncing project update...', 'pending');
                if (db && firebaseUser) {
                    try {
                        await db.collection('projects').doc(project.docId || String(project.id)).set({
                            ...project,
                            updatedAt: firebase.firestore.FieldValue.serverTimestamp()
                        }, { merge: true });
                        updateSyncStatus('Update synced', 'connected');
                    } catch (error) {
                        console.error('Firestore update failed:', error);
                        updateSyncStatus('Update sync failed', 'disconnected');
                        toast('Update saved locally, Firestore sync failed.', 'error');
                    }
                } else {
                    updateSyncStatus('Offline: update queued locally', 'disconnected');
                }

                filteredProjects = [...projects];
                saveToLocalCache();
                applySort();
                renderTable();
                closeModal();
                toast('Project updated successfully!', 'success');
            }

            /* ── EXPORT CSV ────────────────────────────────────────────── */
            function exportCSV() {
                if (!projects.length) {
                    toast('No data to export.', 'error');
                    return;
                }

                const headers = ['Project Name',
                    'Project Type',
                    'Owner',
                    'Leader',
                    'Crew & Role',
                    'Status',
                    'Start Date',
                    'End Date',
                    'Value',
                    'Collected',
                    'Outstanding'];
                const rows = filteredProjects.map(p => [p.projectName, p.projectType, p.owner, p.leader, p.crew,
                p.status, p.startDate, p.endDate, p.value, p.collected, p.outstanding]);
                const csv = [headers,
                    ...rows].map(r => r.map(c => `"${String(c).replace(/"/g, '""')}"`).join(',')).join('\n');
                const blob = new Blob([csv], {
                    type: 'text/csv'
                });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'projectpulse_export.csv';
                a.click();
                URL.revokeObjectURL(url);
                toast('CSV exported!', 'success');
            }

            /* ── HELPERS ───────────────────────────────────────────────── */
            function esc(s) {
                if (!s) return '';
                return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

            }

            function fmtMoney(n) {
                if (!n && n !== 0) return '—';

                return '₹' + Number(n).toLocaleString('en-IN', {
                    minimumFractionDigits: 0, maximumFractionDigits: 2
                });
            }

            function fmtDate(s) {
                if (!s) return '—';
                const d = new Date(s + 'T00:00:00');

                return d.toLocaleDateString('en-IN', {
                    day: '2-digit', month: 'short', year: 'numeric'
                });
            }

            function statusBadge(s) {
                const cls = {
                    'Planning': 'badge-planning', 'In Progress': 'badge-inprogress', 'On Hold': 'badge-onhold', 'Completed': 'badge-completed'
                }

                    ;

                return `<span class="badge ${cls[s] || ''}">${esc(s)}</span>`;
            }

            function toast(msg, type = 'info') {
                const c = document.getElementById('toasts');
                const t = document.createElement('div');
                t.className = 'toast ' + type;

                const icons = {
                    success: '✅', error: '❌', info: 'ℹ️'
                }

                    ;

                t.innerHTML = `<span>${icons[type] || '•'}</span><span>${msg}</span>`;
                c.appendChild(t);

                setTimeout(() => {
                    t.style.opacity = '0'; t.style.transform = 'translateX(20px)'; t.style.transition = 'all 0.3s'; setTimeout(() => t.remove(), 300);
                }

                    , 3500);
            }

        </script>

