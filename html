            .modal {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-lg);
                padding: 32px;
                width: 100%;
                max-width: 640px;
                max-height: 90vh;
                overflow-y: auto;
                box-shadow: var(--shadow-xl);
                animation: modalIn 0.25s ease;
            }

            @keyframes modalIn {
                from {
                    opacity: 0;
                    transform: scale(0.95) translateY(-10px);
                }

                to {
                    opacity: 1;
                    transform: scale(1) translateY(0);
                }
